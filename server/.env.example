# Copy to .env and fill in. .env is gitignored — never commit real values.

# Dashboard timezone — all calendar day/time math uses this, regardless of the
# host machine's clock (important on a UTC VPS). Defaults to America/Detroit.
DASHBOARD_TZ=America/Detroit

# --- Notion (tasks + projects) ---
NOTION_TOKEN=
NOTION_TASKS_DB_ID=
NOTION_PROJECTS_DB_ID=
# Optional — auto-discovered by title ("Companies") when omitted. Used for logo storage.
NOTION_COMPANIES_DB_ID=

# --- Google Calendar (work calendar, read-only via service account) ---
# Calendar ID is usually your email address (calendar settings → "Integrate calendar")
GOOGLE_CALENDAR_ID=
# Absolute path to the downloaded service-account JSON key file
GOOGLE_SERVICE_ACCOUNT_KEY=

# --- Guppy / Hermes (later, once deployed near the agent) ---
GUPPY_API_URL=
GUPPY_API_KEY=
